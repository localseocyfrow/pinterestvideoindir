---
import ToolPageLayout from '../layouts/ToolPageLayout.astro';
import ShortAnswerBox from '../components/ShortAnswerBox.astro';
import RelatedGuides from '../components/RelatedGuides.astro';
import ToolCta from '../components/ToolCta.astro';
import { MP4_FAQ } from '../data/faq';

const path = '/pinterest-mp4-indir/';
const title = 'Pinterest MP4 İndir – HD MP4 Video Linki (Ücretsiz)';
const description =
  'Pinterest videosunu MP4 olarak indirin: bağlantıyı yapıştırın, HD (1080p) MP4 dosyasını dönüştürücü olmadan doğrudan kaydedin. Tüm cihazlarda ücretsiz ve filigransız.';

const crumbs = [
  { name: 'Ana Sayfa', href: '/' },
  { name: 'MP4 İndir', href: path },
];

const howTo = {
  name: 'Pinterest videosunu MP4 olarak indirme',
  description:
    'Pinterest videosunu MP4 olarak indirmek için bağlantıyı kopyalayın, araca yapıştırın, HD kaliteyi seçin ve MP4 dosyasını kaydedin.',
  steps: [
    { name: 'Bağlantıyı kopyala', text: 'Videoyu Pinterest’te açıp “Paylaş → Bağlantıyı kopyala” deyin.' },
    { name: 'Araca yapıştır', text: 'Bağlantıyı yukarıdaki kutuya yapıştırıp “İndir”e basın.' },
    { name: 'MP4 kalitesini seç', text: 'HD (1080p) veya varsa 4K MP4 seçeneğini seçin.' },
    { name: 'MP4 olarak kaydet', text: 'İndirme bağlantısına dokunup videoyu MP4 olarak cihazınıza kaydedin.' },
  ],
};
---

<ToolPageLayout
  title={title}
  description={description}
  path={path}
  eyebrow="MP4 · HD · Doğrudan link"
  h1="Pinterest MP4 İndir"
  lead="Pinterest videolarını dönüştürücü olmadan doğrudan MP4 olarak indirin: bağlantıyı yapıştırın, HD (1080p) veya 4K kaliteyi seçin, videoyu filigransız MP4 dosyası olarak kaydedin."
  kind="video"
  placeholder="Pinterest video bağlantısını buraya yapıştırın…"
  crumbs={crumbs}
  faq={MP4_FAQ}
  faqTitle="Pinterest MP4 indirme — SSS"
  howTo={howTo}
>
  <ShortAnswerBox question="Pinterest videosu MP4 olarak nasıl indirilir?">
    <p class="mt-0" style="margin:0">
      Videonun bağlantısını <strong>kopyalayın</strong>, kutuya
      <strong>yapıştırın</strong> ve <strong>“İndir”</strong>e basın. Pinterest
      videoları zaten MP4 tabanlı olduğu için ayrı bir <strong>MP4
      dönüştürücüye</strong> gerek kalmadan videoyu doğrudan
      <strong>MP4</strong> olarak kaydedersiniz. İndirme seçenekleri arasından
      <strong>HD (1080p)</strong> ya da varsa 4K kaliteyi seçebilirsiniz.
    </p>
  </ShortAnswerBox>

  <h2>Dönüştürücüsüz: doğrudan MP4 indirme</h2>
  <p>
    Birçok kullanıcı “Pinterest videosunu MP4’e çevirmek” için ayrı bir
    <strong>MP4 dönüştürücü</strong> aradığını düşünür; oysa Pinterest videoları
    zaten MP4 tabanlı sunulur. Aracımız videonun kaynağındaki MP4 dosyasını
    yeniden sıkıştırmadan verdiği için ne bir program kurmanız ne de çevrimiçi
    bir dönüştürme adımı geçmeniz gerekir. Bağlantıyı yapıştırdığınızda size
    doğrudan indirilebilir bir <strong>MP4 bağlantısı</strong> sunulur.
  </p>

  <h2>HD MP4: 1080p ve 4K kalite</h2>
  <p>
    MP4 yalnızca bir kapsayıcı formattır; asıl kaliteyi videonun çözünürlüğü
    belirler. Bu yüzden aynı MP4 dosyası hem <strong>HD 720p</strong> hem
    <strong>Full HD 1080p</strong> hem de <strong>4K (2160p)</strong>
    olabilir. Aracımız kaynakta gerçekten var olan çözünürlükleri listeler;
    böylece bulanık, şişirilmiş bir dosya yerine net bir HD MP4 indirirsiniz.
    Çözünürlükler arasındaki farkı
    <a href="/pinterest-4k-video-indir/">4K video indirme sayfamızda</a>
    ayrıntılı bulabilir, düşük kalite sorunları için
    <a href="/pinterest-video-kalitesi/">video kalitesi rehberimize</a>
    göz atabilirsiniz.
  </p>

  <h2>MP4 formatının avantajları</h2>
  <ul>
    <li><strong>Evrensel uyumluluk:</strong> Android, iPhone, Windows, Mac, tablet ve akıllı TV’lerde ek codec olmadan oynatılır.</li>
    <li><strong>Küçük dosya, yüksek kalite:</strong> Verimli H.264/H.265 sıkıştırma sayesinde kalite/boyut dengesi idealdir.</li>
    <li><strong>Kolay paylaşım:</strong> WhatsApp, Instagram ve e-posta ile doğrudan gönderilebilir.</li>
    <li><strong>Düzenlemeye uygun:</strong> CapCut, iMovie, Clipchamp gibi tüm editörler MP4’ü destekler.</li>
  </ul>

  <h2>MP4 indirmenin adımları</h2>
  <div class="steps" style="margin:20px 0">
    <div class="step"><h3>Bağlantıyı kopyala</h3><p>Pinterest’te videoyu açın, “Paylaş → Bağlantıyı kopyala” deyin.</p></div>
    <div class="step"><h3>Araca yapıştır</h3><p>Bağlantıyı yukarıdaki kutuya yapıştırıp “İndir”e basın.</p></div>
    <div class="step"><h3>Kaliteyi seç</h3><p>HD (1080p) ya da varsa 4K MP4 seçeneğini seçin.</p></div>
    <div class="step"><h3>MP4 olarak kaydet</h3><p>İndirme bağlantısına dokunup videoyu cihazınıza kaydedin.</p></div>
  </div>

  <p class="disclaimer" role="note" style="margin-top:22px">
    <strong>Sorumlu kullanım — </strong>Yalnızca size ait olan veya indirme
    iznine sahip olduğunuz içerikleri kaydetmenizi öneririz. Pinterest ile resmi
    bir bağlantımız yoktur.
  </p>

  <ToolCta
    slot="after"
    title="Videoyu hemen MP4 olarak indirin"
    text="Bağlantıyı yapıştırın, HD MP4 seçin ve videoyu saniyeler içinde kaydedin — dönüştürücü gerekmez."
    href="/pinterest-video-indir/"
    label="Pinterest Video İndir"
  />

  <RelatedGuides
    slot="after"
    title="İlgili araçlar ve rehberler"
    items={[
      { title: 'Pinterest Video İndir', href: '/pinterest-video-indir/', description: 'Tüm cihazlarda HD, Full HD ve 4K MP4 indirme aracı.' },
      { title: 'Pinterest HD Video İndir', href: '/pinterest-hd-video-indir/', description: 'Full HD (1080p) kalitede net indirme.' },
      { title: 'Pinterest 4K Video İndir', href: '/pinterest-4k-video-indir/', description: 'En yüksek çözünürlükte Ultra HD MP4 indirin.' },
      { title: 'Pinterest Video Kalitesi', href: '/pinterest-video-kalitesi/', description: 'Video neden düşük kaliteli iniyor ve nasıl HD indirilir?' },
      { title: 'Pinterest Video Link İndir', href: '/pinterest-video-link-indir/', description: 'Pin bağlantısını yapıştırarak indirme.' },
      { title: 'Filigransız Video İndir', href: '/pinterest-filigransiz-video-indir/', description: 'Logosuz, temiz MP4 indirme.' },
      { title: 'Pinterest Video İndirici', href: '/pinterest-video-indirici/', description: 'Online, kurulumsuz indirme aracı.' },
      { title: 'Video İndir Galeriye', href: '/pinterest-video-galeriye-indir/', description: 'Videoyu telefon galerinize kaydedin.' },
    ]}
  />
</ToolPageLayout>

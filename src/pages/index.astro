---
import BaseLayout from '../layouts/BaseLayout.astro';
import Downloader from '../components/Downloader.astro';
import HowToDownloadVisual from '../components/HowToDownloadVisual.astro';
import DeviceExperience from '../components/DeviceExperience.astro';
import SystemCompatibility from '../components/SystemCompatibility.astro';
import AboutSection from '../components/AboutSection.astro';
import Faq from '../components/Faq.astro';
import VideoTutorial from '../components/VideoTutorial.astro';
import { SITE } from '../data/site';
import { HOME_FAQ } from '../data/faq';
import { HOME_TUTORIALS } from '../data/videos';
import {
  webAppSchema,
  faqSchema,
  howToSchema,
  videoObjectSchema,
  type Step,
} from '../lib/schema';

const title = 'Pinterest Video İndir – HD MP4 Video İndirici (Ücretsiz)';
const description =
  'Pinterest videolarını HD, Full HD (1080p) ve 4K kalitede, ücretsiz ve ' +
  'filigransız indirin. Bağlantıyı yapıştırın, tek tıkla MP4 olarak ' +
  'galerinize kaydedin. Kayıt ve reklam yok.';

const steps: Step[] = [
  {
    name: 'Video bağlantısını kopyalayın',
    text: 'Pinterest uygulamasında veya sitesinde indirmek istediğiniz videoyu açın. “Paylaş” düğmesine dokunun ve “Bağlantıyı kopyala” seçeneğini seçin.',
  },
  {
    name: 'Bağlantıyı yapıştırın',
    text: 'Kopyaladığınız Pinterest bağlantısını yukarıdaki indirme kutusuna yapıştırın.',
  },
  {
    name: 'İndir düğmesine basın',
    text: '“İndir” düğmesine tıklayın. Video birkaç saniye içinde analiz edilir.',
  },
  {
    name: 'Kaliteyi seçip kaydedin',
    text: 'HD, Full HD veya standart kaliteyi seçin ve videoyu cihazınıza (galeri veya Dosyalar) kaydedin.',
  },
];

const features = [
  {
    t: 'HD & 4K Kalite',
    d: 'Videoları kaynaktaki en yüksek çözünürlükte — HD 720p, Full HD 1080p ve mümkün olduğunda 4K — indirin.',
    icon: 'M4 6h16v12H4z M2 9l3-3h14l3 3',
  },
  {
    t: 'Filigransız',
    d: 'İndirilen videolarda logo veya filigran olmaz. Temiz, orijinal görüntü kalitesi.',
    icon: 'M20 6 9 17l-5-5',
  },
  {
    t: '%100 Ücretsiz',
    d: 'Sınırsız indirme. Gizli ücret yok, abonelik yok, kredi kartı istenmez.',
    icon: 'M12 1v22 M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6',
  },
  {
    t: 'Kayıt Gerektirmez',
    d: 'Hesap açmadan, uygulama kurmadan doğrudan tarayıcıdan indirin.',
    icon: 'M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4 M10 17l5-5-5-5 M15 12H3',
  },
  {
    t: 'Tüm Cihazlar',
    d: 'Android, iPhone (iOS), tablet ve bilgisayarda sorunsuz çalışır.',
    icon: 'M5 4h14v12H5z M2 20h20 M9 16v4 M15 16v4',
  },
  {
    t: 'Hızlı & Güvenli',
    d: 'Saniyeler içinde indirin. Bağlantınız saklanmaz, verileriniz gizli kalır.',
    icon: 'M13 2 3 14h7l-1 8 10-12h-7z',
  },
];

const compareRows = [
  ['HD / 4K indirme', 'Var', 'Kısıtlı'],
  ['Filigransız video', 'Var', 'Genelde yok'],
  ['Ücret', 'Ücretsiz', 'Ücretli / kredili'],
  ['Kayıt / uygulama', 'Gerekmez', 'Çoğunlukla gerekir'],
  ['Reklam', 'Reklamsız deneyim', 'Yoğun reklam'],
  ['GIF & görsel desteği', 'Var', 'Nadiren'],
];
---

<BaseLayout
  title={title}
  description={description}
  path="/"
  schemas={[
    webAppSchema(),
    howToSchema({
      name: 'Pinterest videosu nasıl indirilir?',
      description:
        'Pinterest videolarını HD kalitede indirmek için bağlantıyı kopyalayın, yapıştırın ve indirin.',
      steps,
    }),
    faqSchema(HOME_FAQ),
    ...HOME_TUTORIALS.map((v) =>
      videoObjectSchema({
        name: v.title,
        description: v.description,
        videoId: v.id,
        path: '/',
      }),
    ),
  ]}
>
  <!-- Hero + tool -->
  <section class="hero">
    <div class="container">
      <div style="display:grid;gap:40px;grid-template-columns:1fr;max-width:760px;margin-inline:auto;text-align:center">
        <div class="stack">
          <span class="eyebrow">Ücretsiz · Filigransız · HD</span>
          <h1 style="margin-inline:auto">Pinterest Video İndir</h1>
          <p class="lead" style="margin-inline:auto">
            Pinterest videolarını <strong>HD kalitede</strong>,
            <strong>filigransız</strong> ve <strong>ücretsiz</strong> indirin.
            Bağlantıyı yapıştırın, tek tıkla MP4 olarak kaydedin — kayıt yok,
            reklam yok.
          </p>
        </div>

        <Downloader />

        <div class="stats">
          <div class="stat"><b>%100</b><span>Ücretsiz</span></div>
          <div class="stat"><b>4K</b><span>Kaliteye kadar</span></div>
          <div class="stat"><b>0</b><span>Filigran &amp; reklam</span></div>
          <div class="stat"><b>∞</b><span>Sınırsız indirme</span></div>
        </div>

        <div class="trust-row" style="justify-content:center">
          <span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6 9 17l-5-5"/></svg>
            Kayıt gerekmez
          </span>
          <span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6 9 17l-5-5"/></svg>
            Filigransız HD
          </span>
          <span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6 9 17l-5-5"/></svg>
            Telefon &amp; PC uyumlu
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- How to download (premium visual timeline) -->
  <HowToDownloadVisual target="#arac" />

  <!-- Tool selector cards -->
  <section class="section" style="padding-bottom:0">
    <div class="container">
      <div class="center section-head">
        <span class="eyebrow">Tüm araçlar</span>
        <h2>Ne indirmek istiyorsunuz?</h2>
        <p class="lead" style="margin-inline:auto">
          Pinterest'in her içerik türü için ücretsiz, filigransız bir araç.
        </p>
      </div>
      <div class="toolcards">
        <a class="toolcard" href="/pinterest-video-indir/">
          <span class="ico" aria-hidden="true"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m10 8 6 4-6 4V8z"/><rect x="2" y="4" width="20" height="16" rx="3"/></svg></span>
          <h3>Video İndir</h3>
          <p>HD, Full HD ve 4K MP4 video indirme.</p>
          <span class="go">Aç →</span>
        </a>
        <a class="toolcard" href="/pinterest-resim-indir/">
          <span class="ico" aria-hidden="true"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="3"/><circle cx="9" cy="9" r="2"/><path d="m21 15-5-5L5 21"/></svg></span>
          <h3>Resim İndir</h3>
          <p>Tam çözünürlükte, filigransız görsel indirme.</p>
          <span class="go">Aç →</span>
        </a>
        <a class="toolcard" href="/pinterest-gif-indir/">
          <span class="ico" aria-hidden="true"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="3"/><path d="M7 9v6M11 9v6M11 9H9.5M11 12H9.5M15 9h2M15 9v6"/></svg></span>
          <h3>GIF İndir</h3>
          <p>Hareketli GIF'leri GIF veya MP4 olarak kaydedin.</p>
          <span class="go">Aç →</span>
        </a>
        <a class="toolcard" href="/pinterest-karusel-indir/">
          <span class="ico" aria-hidden="true"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="7" y="5" width="10" height="14" rx="2"/><path d="M4 8v8M20 8v8"/></svg></span>
          <h3>Karusel İndir</h3>
          <p>Çoklu görsel pinlerindeki tüm medyayı indirin.</p>
          <span class="go">Aç →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- AEO answer box -->
  <section class="section" style="padding-top:56px">
    <div class="container">
      <div class="answer-box" style="max-width:820px;margin-inline:auto">
        <p class="q">Pinterest videosu nasıl indirilir?</p>
        <p class="mt-0" style="margin:0">
          Pinterest videosu indirmek için videonun <strong>bağlantısını
          kopyalayın</strong>, bu bağlantıyı Pinterest Video İndir aracındaki
          kutuya <strong>yapıştırın</strong> ve <strong>“İndir”</strong>
          düğmesine basın. Ardından HD veya standart kaliteyi seçerek videoyu
          MP4 olarak telefonunuza ya da bilgisayarınıza kaydedin. İşlem
          ücretsizdir, üyelik ya da uygulama gerektirmez.
        </p>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="section section-soft">
    <div class="container">
      <div class="center" style="margin-bottom:44px">
        <span class="eyebrow">Neden biz?</span>
        <h2>En hızlı Pinterest video indirici</h2>
        <p class="lead">
          İndirme deneyimini basit, hızlı ve tamamen ücretsiz tutuyoruz.
        </p>
      </div>
      <div class="grid">
        {
          features.map((f) => (
            <article class="card">
              <span class="ico" aria-hidden="true">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d={f.icon} />
                </svg>
              </span>
              <h3>{f.t}</h3>
              <p>{f.d}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Comparison -->
  <section class="section section-soft">
    <div class="container" style="max-width:820px">
      <div class="center" style="margin-bottom:36px">
        <span class="eyebrow">Karşılaştırma</span>
        <h2>Diğer araçlardan farkımız</h2>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th style="text-align:right">Özellik</th>
              <th>{SITE.name}</th>
              <th>Diğer araçlar</th>
            </tr>
          </thead>
          <tbody>
            {
              compareRows.map((r) => (
                <tr>
                  <td style="font-weight:600;color:var(--ink)">{r[0]}</td>
                  <td style="color:var(--ok);font-weight:700">{r[1]}</td>
                  <td>{r[2]}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="section">
    <div class="container">
      <div class="center" style="margin-bottom:44px">
        <span class="eyebrow">Kullanım alanları</span>
        <h2>Pinterest videolarını neden indirmelisiniz?</h2>
      </div>
      <div class="grid">
        <article class="card">
          <h3>Çevrimdışı izleme</h3>
          <p>Beğendiğiniz tarif, DIY veya ilham videolarını internet olmadan da izleyin.</p>
        </article>
        <article class="card">
          <h3>İlham panosu</h3>
          <p>Moodboard, tasarım ve dekorasyon fikirlerinizi cihazınızda arşivleyin.</p>
        </article>
        <article class="card">
          <h3>İçerik üretimi</h3>
          <p>İlham aldığınız içerikleri referans olarak saklayın (telif haklarına saygı göstererek).</p>
        </article>
        <article class="card">
          <h3>Kolay paylaşım</h3>
          <p>Videoyu galerinize kaydedip WhatsApp, Instagram veya diğer platformlarda paylaşın.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- Device experience -->
  <DeviceExperience />

  <!-- OS compatibility -->
  <SystemCompatibility />

  <!-- Video tutorials (per device) -->
  <section class="section section-soft" id="video-anlatim">
    <div class="container">
      <div class="center" style="margin-bottom:44px">
        <span class="eyebrow">Video anlatım</span>
        <h2>Cihazınıza göre video ile anlatım</h2>
        <p class="lead" style="margin-inline:auto">
          Pinterest videosu indirmeyi adım adım ekranda görün. iPhone, Android,
          Mac ve Windows için kısa anlatım videoları.
        </p>
      </div>
      <div class="video-grid">
        {
          HOME_TUTORIALS.map((v) => (
            <article class="video-grid__item">
              <VideoTutorial id={v.id} title={v.iframeTitle} />
              <h3>
                <a href={v.path}>{v.device}</a>
              </h3>
              <p>{v.title}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- About us -->
  <AboutSection />

  <Faq items={HOME_FAQ} />

  <!-- CTA band -->
  <section class="section" style="padding-top:0">
    <div class="container">
      <div class="cta-band">
        <h2>Hemen Pinterest videosu indirin</h2>
        <p>
          Ücretsiz, filigransız ve HD kalitede. Bağlantıyı yapıştırın,
          gerisini biz halledelim.
        </p>
        <p style="margin-top:22px">
          <a class="btn btn-primary" href="/#arac">Video İndirmeye Başla</a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .video-grid {
    display: grid;
    gap: 28px;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  }
  .video-grid__item h3 {
    margin: 14px 0 4px;
    font-size: 1.05rem;
  }
  .video-grid__item h3 a {
    color: var(--ink);
    text-decoration: none;
  }
  .video-grid__item h3 a:hover {
    color: var(--brand);
    text-decoration: underline;
  }
  .video-grid__item p {
    margin: 0;
    color: var(--ink-2);
    font-size: 0.94rem;
  }
</style>

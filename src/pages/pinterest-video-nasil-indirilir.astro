---
import ToolPageLayout from '../layouts/ToolPageLayout.astro';
import ShortAnswerBox from '../components/ShortAnswerBox.astro';
import RelatedGuides from '../components/RelatedGuides.astro';
import ToolCta from '../components/ToolCta.astro';
import { HOWTO_FAQ } from '../data/faq';

const path = '/pinterest-video-nasil-indirilir/';
const title = 'Pinterest Video Nasıl İndirilir? Adım Adım Rehber (2026)';
const description =
  'Pinterest videosu nasıl indirilir? Telefon (Android, iPhone) ve bilgisayarda adım adım, resimli anlatım. Bağlantıyı yapıştırın, videoyu ücretsiz MP4 indirin.';

const crumbs = [
  { name: 'Ana Sayfa', href: '/' },
  { name: 'Video Nasıl İndirilir', href: path },
];

const howTo = {
  name: 'Pinterest videosu nasıl indirilir',
  description:
    'Pinterest videosunu telefon veya bilgisayarda indirmek için bağlantıyı kopyalayın, araca yapıştırın ve kaydedin.',
  steps: [
    { name: 'Videoyu aç ve bağlantıyı kopyala', text: 'Pinterest’te videoyu açın, “Paylaş → Bağlantıyı kopyala” deyin.' },
    { name: 'Bağlantıyı araca yapıştır', text: 'Bağlantıyı yukarıdaki kutuya yapıştırıp “İndir”e basın.' },
    { name: 'Kaliteyi seç', text: 'HD, Full HD veya 4K seçeneklerinden birini seçin.' },
    { name: 'Videoyu kaydet', text: 'Video MP4 olarak telefonunuza veya bilgisayarınıza kaydedilir.' },
  ],
};
---

<ToolPageLayout
  title={title}
  description={description}
  path={path}
  eyebrow="Adım adım rehber"
  h1="Pinterest Video Nasıl İndirilir?"
  lead="Pinterest videosunu telefon ve bilgisayarda indirmenin en kolay yolu: bağlantıyı yapıştırın, kaliteyi seçin, MP4 olarak kaydedin. Aşağıda adım adım anlatıyoruz."
  kind="video"
  placeholder="Pinterest video bağlantısını buraya yapıştırın…"
  crumbs={crumbs}
  faq={HOWTO_FAQ}
  faqTitle="Pinterest video indirme — SSS"
  howTo={howTo}
>
  <ShortAnswerBox question="Pinterest videosu nasıl indirilir?">
    <p class="mt-0" style="margin:0">
      Videoyu Pinterest’te açın ve <strong>“Paylaş → Bağlantıyı kopyala”</strong>
      deyin. Kopyaladığınız bağlantıyı yukarıdaki kutuya
      <strong>yapıştırın</strong>, <strong>“İndir”</strong>e basın ve kaliteyi
      seçerek videoyu <strong>MP4</strong> olarak kaydedin. İşlem hem telefonda
      hem bilgisayarda birkaç saniye sürer.
    </p>
  </ShortAnswerBox>

  <h2>Adım adım Pinterest video indirme</h2>
  <div class="steps" style="margin:20px 0">
    <div class="step"><h3>Videoyu aç</h3><p>Pinterest uygulaması veya web sitesinde indirmek istediğiniz videoyu açın.</p></div>
    <div class="step"><h3>Bağlantıyı kopyala</h3><p>“Paylaş” simgesine dokunup “Bağlantıyı kopyala” deyin.</p></div>
    <div class="step"><h3>Yapıştır</h3><p>Bağlantıyı bu sayfadaki indirme kutusuna yapıştırın.</p></div>
    <div class="step"><h3>Kaliteyi seç &amp; indir</h3><p>“İndir”e basın, çözünürlüğü seçin ve videoyu kaydedin.</p></div>
  </div>

  <h2>Telefonda Pinterest videosu nasıl indirilir?</h2>
  <p>
    <strong>Android:</strong> Pinterest uygulamasında videoyu açıp “Paylaş →
    Bağlantıyı kopyala” deyin, bağlantıyı tarayıcıdaki aracımıza yapıştırın ve
    indirin. Video doğrudan galeriye kaydedilir. <strong>iPhone (iOS):</strong>
    Aynı şekilde bağlantıyı kopyalayıp indirin; video önce “Dosyalar”a iner,
    ardından oradan “Videoyu Kaydet” ile Fotoğraflar’a eklenir. Ayrıntı için
    <a href="/pinterest-video-galeriye-indir/">videoyu galeriye indirme
    rehberimize</a> bakın.
  </p>

  <h2>Bilgisayarda Pinterest videosu nasıl indirilir?</h2>
  <p>
    Bilgisayarda videonun altındaki “Paylaş” düğmesinden bağlantıyı kopyalayın
    ya da tarayıcının adres çubuğundaki URL’yi alın. Bağlantıyı aracımıza
    yapıştırıp “İndir”e bastığınızda video, tarayıcınızın “İndirilenler”
    klasörüne MP4 olarak kaydedilir. Windows ve macOS’ta aynı şekilde çalışır.
  </p>

  <h2>İpuçları ve sık karşılaşılan sorunlar</h2>
  <ul>
    <li><strong>Bağlantı çalışmıyor:</strong> URL’nin <code>pin.it</code> veya <code>pinterest.com</code> ile başladığından emin olun.</li>
    <li><strong>Video özel/gizli:</strong> Yalnızca herkese açık pinler indirilebilir.</li>
    <li><strong>En yüksek kalite:</strong> Kaynakta varsa <a href="/pinterest-4k-video-indir/">4K çözünürlük</a> seçeneğini tercih edin.</li>
    <li><strong>Filigran istemiyorsanız:</strong> Videolar zaten <a href="/pinterest-filigransiz-video-indir/">filigransız</a> indirilir.</li>
  </ul>

  <ToolCta
    slot="after"
    title="Şimdi deneyin"
    text="Bağlantıyı yapıştırın ve Pinterest videosunu saniyeler içinde indirin."
    href="/pinterest-video-indir/"
    label="Pinterest Video İndir"
  />

  <RelatedGuides
    slot="after"
    title="İlgili araçlar ve rehberler"
    items={[
      { title: 'Pinterest Video İndir', href: '/pinterest-video-indir/', description: 'HD, Full HD ve 4K MP4 indirme aracı.' },
      { title: 'Video İndir Galeriye', href: '/pinterest-video-galeriye-indir/', description: 'Videoyu doğrudan telefon galerinize kaydedin.' },
      { title: 'Filigransız Video İndir', href: '/pinterest-filigransiz-video-indir/', description: 'Logo ve damga olmadan temiz video.' },
      { title: 'Nasıl Kullanılır', href: '/nasil-kullanilir/', description: 'Sitenin tüm araçları için genel rehber.' },
    ]}
  />
</ToolPageLayout>

---
// Real Pinterest downloader tool.
// Posts to /api/download, renders media options, downloads via /api/file proxy.
// Keeps the site design system (.tool, .tool-input, .btn) and Turkish UI.
interface Props {
  heading?: string;
  placeholder?: string;
  kind?: 'video' | 'gif' | 'gorsel';
}
const {
  heading,
  placeholder = 'Pinterest bağlantısını buraya yapıştırın…',
  kind = 'video',
} = Astro.props;

const label =
  kind === 'gif' ? 'GIF' : kind === 'gorsel' ? 'Görsel' : 'Video';
---

<div class="tool" id="arac">
  {heading && <h2 style="margin-bottom:6px">{heading}</h2>}

  <form class="tool-row" id="pin-form" role="search" aria-label={`Pinterest ${label} indirici`}>
    <label class="visually-hidden" for="pin-url">Pinterest bağlantısı</label>
    <input
      class="tool-input"
      id="pin-url"
      name="url"
      type="url"
      inputmode="url"
      autocomplete="off"
      placeholder={placeholder}
      required
    />
    <button class="btn btn-primary" id="pin-submit" type="submit">
      İndir
    </button>
  </form>

  <div class="tool-steps-mini" aria-hidden="true">
    <span>1 · Bağlantıyı kopyala</span>
    <span>2 · Yapıştır</span>
    <span>3 · İndir</span>
  </div>

  <p class="tool-status" id="pin-status" role="status" aria-live="polite"></p>

  <div class="tool-results" id="pin-results" aria-live="polite"></div>

  <p class="tool-note">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <rect x="3" y="11" width="18" height="10" rx="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" />
    </svg>
    Bağlantınız yalnızca indirme için kullanılır, kaydedilmez. Kayıt gerekmez.
  </p>

  <p class="tool-disclaimer">
    Yalnızca herkese açık pinlerle çalışır. İndirdiğiniz içeriklerin telif
    haklarına saygı gösterin ve yalnızca kişisel amaçlarla kullanın.
    Pinterest ile resmi bir bağlantımız yoktur.
  </p>
</div>

<script>
  import { scrollToDownloadResults } from '../lib/scrollToDownloadResults';
  import { setupDownloadAnotherButton } from '../lib/setupDownloadAnotherButton';

  const form = document.querySelector<HTMLFormElement>('#pin-form');
  const input = document.querySelector<HTMLInputElement>('#pin-url');
  const submitButton = document.querySelector<HTMLButtonElement>('#pin-submit');
  const status = document.querySelector<HTMLElement>('#pin-status');
  const results = document.querySelector<HTMLElement>('#pin-results');
  const defaultButtonLabel = 'İndir';

  if (form && input && submitButton && status && results) {
    function safeHtml(text: string): string {
      return text
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');
    }

    function qualityLabel(item: { type: string; quality?: string }): string {
      if (item.quality) {
        const map: Record<string, string> = {
          Original: 'Orijinal',
          Standard: 'Standart',
          GIF: 'GIF',
        };
        return safeHtml(map[item.quality] ?? item.quality);
      }
      return item.type === 'video' ? 'Standart' : 'Orijinal';
    }

    function createDownloadOption(
      item: { type: string; url: string; quality?: string },
      index: number,
    ): string {
      const label = item.type === 'video' ? 'Video' : 'Görsel';
      const fileBaseName = `pin-${label.toLowerCase()}-${index + 1}`;
      const downloadHref = `/api/file?url=${encodeURIComponent(item.url)}&name=${encodeURIComponent(fileBaseName)}`;

      return `
        <div class="option-row">
          <div class="option-left">
            <span class="quality-chip">${qualityLabel(item)}</span>
            <span class="option-type">${label}</span>
          </div>
          <a class="download-link btn btn-primary" href="${downloadHref}" rel="nofollow" download>
            İndir
          </a>
        </div>
      `;
    }

    function renderResultPanel(
      items: { type: string; url: string; quality?: string }[],
    ): string {
      if (!items || items.length === 0) return '';

      const primary = items[0];
      const mediaPreview =
        primary.type === 'video'
          ? `<video controls preload="metadata" src="${safeHtml(primary.url)}"></video>`
          : `<img src="${safeHtml(primary.url)}" alt="İndirilecek içerik önizlemesi" loading="lazy" />`;

      const options = items
        .map((item, index) => createDownloadOption(item, index))
        .join('');

      return `
        <section class="result-panel">
          <header class="result-header">
            <div>
              <p class="result-kicker">Hazır</p>
              <h3 style="margin:0">İndirmeniz hazır</h3>
            </div>
            <span class="result-count">${items.length} seçenek</span>
          </header>
          <div class="result-content">
            <div class="preview-box">
              ${mediaPreview}
            </div>
            <div class="options-box">
              <h4 style="margin:0 0 10px">Bir dosya seçin</h4>
              ${options}
              <div class="result-footer-actions">
                <button type="button" class="btn btn-ghost download-another-btn" data-download-another>Başka Bir İçerik İndir</button>
              </div>
            </div>
          </div>
        </section>
      `;
    }

    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      const url = input.value.trim();
      if (!url) {
        status.textContent = 'Lütfen önce bir bağlantı yapıştırın.';
        return;
      }

      submitButton.disabled = true;
      submitButton.textContent = 'Bir saniye…';
      status.textContent = 'Pin analiz ediliyor…';
      results.innerHTML = '';

      try {
        const response = await fetch('/api/download', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ url }),
        });
        const payload = await response.json();

        if (!response.ok || !payload.success) {
          throw new Error(
            payload.message || 'Bu bağlantı işlenemedi. Lütfen tekrar deneyin.',
          );
        }

        const { items } = payload.data;
        results.innerHTML = renderResultPanel(items);
        status.textContent = `${items.length} indirme seçeneği bulundu.`;
        if (items.length > 0) {
          scrollToDownloadResults(results);
          setupDownloadAnotherButton(results, input, status);
        }
      } catch (error) {
        status.textContent =
          error instanceof Error
            ? error.message
            : 'Bir şeyler ters gitti. Lütfen tekrar deneyin.';
      } finally {
        submitButton.disabled = false;
        submitButton.textContent = defaultButtonLabel;
      }
    });
  }
</script>
